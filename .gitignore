# Python
__pycache__/
*.pyc
.venv/
venv/

# Secrets — never commit
.env

# Personal profile override — local-only (the repo is public). The real "Mohith
# profile" lives here or in the OH_PROFILE_JSON secret; only the .example is tracked.
profile.local.json

# Logs (regenerated each run; not worth versioning)
logs/*.log

# TaskFlow's own local data/log (not part of this project)
.taskflow/

# NOTE: data/*.json is intentionally NOT ignored — the cloud workflow commits
# seen_items.json / history.json back so dedup survives across daily runs.
# Exception: dumped.json + tracker.json are LOCAL state (taps happen locally only).
data/dumped.json
data/tracker.json

# Project brain — local-only, never public
CLAUDE.md
