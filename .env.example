# Copy this file to ".env" and fill in your own values.
# .env is read automatically at startup (see config.py). Never commit your real .env.

# Your private ntfy.sh topic. Anyone who knows this string can read your alerts,
# so keep it secret and hard to guess. Pick something random and unguessable.
NTFY_TOPIC=your-private-topic-here

# clist.by competitive-programming contests (free API key).
# Register at https://clist.by, then copy your username + key from
# https://clist.by/api/v4/doc/  (shown at the top when logged in).
CLIST_USERNAME=
CLIST_API_KEY=

# ─── Phase 2 — LLM scoring (provider-agnostic chain) ─────────────────
# The scorer tries these in order and falls through on quota/error. All are FREE,
# no credit card. Set at least one (Groq recommended). Leave the rest blank until
# you want backups — they light up automatically once a key is present.
#   Groq (primary, fastest, ~1,000 req/day):   https://console.groq.com
GROQ_API_KEY=
#   Cerebras (backup, ~1M tokens/day):          https://cloud.cerebras.ai
CEREBRAS_API_KEY=
#   OpenRouter (backup, many free models):      https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NOTE: Gemini is intentionally NOT used by this project — that quota is reserved
# for Nova's Kaggle x Google capstone. (GEMINI_API_KEY here would be ignored.)

# ─── Phase C — Telegram two-way control (FREE, optional) ─────────────
# When both are set, the digest is ALSO sent to Telegram with tap-to-act buttons.
# Setup: message @BotFather -> /newbot -> paste the token below. Then run
# `python telegram_listener.py`, message your bot /start, and it prints your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Legacy / unused.
ANTHROPIC_API_KEY=
